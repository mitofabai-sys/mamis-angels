# Supabase — copy from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, never use NEXT_PUBLIC_ prefix
SUPABASE_SERVICE_ROLE_KEY=

# Twilio — for SMS notifications (PH format: +63XXXXXXXXXX)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend — for email notifications
# Requires domain verification in production
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
